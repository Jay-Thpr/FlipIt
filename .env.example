# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000

# Agent networking
AGENT_HOST=127.0.0.1
AGENT_EXECUTION_MODE=local_functions

# Internal security
INTERNAL_API_TOKEN=dev-internal-token

# Agent execution
AGENT_TIMEOUT_SECONDS=30
BUY_AGENT_MAX_RETRIES=1

# Browser Use / Gemini
GOOGLE_API_KEY=
ANONYMIZED_TELEMETRY=false
BROWSER_USE_GEMINI_MODEL=gemini-2.0-flash
BROWSER_USE_PROFILE_ROOT=profiles
BROWSER_USE_MAX_STEPS=15
BROWSER_USE_FORCE_FALLBACK=false

# Fetch.ai / Agentverse
AGENTVERSE_API_KEY=
FETCH_USE_LOCAL_ENDPOINT=false
VISION_FETCH_AGENT_SEED=vision-fetch-agent-seed
EBAY_SOLD_COMPS_FETCH_AGENT_SEED=ebay-sold-comps-fetch-agent-seed
PRICING_FETCH_AGENT_SEED=pricing-fetch-agent-seed
DEPOP_LISTING_FETCH_AGENT_SEED=depop-listing-fetch-agent-seed
DEPOP_SEARCH_FETCH_AGENT_SEED=depop-search-fetch-agent-seed
EBAY_SEARCH_FETCH_AGENT_SEED=ebay-search-fetch-agent-seed
MERCARI_SEARCH_FETCH_AGENT_SEED=mercari-search-fetch-agent-seed
OFFERUP_SEARCH_FETCH_AGENT_SEED=offerup-search-fetch-agent-seed
RANKING_FETCH_AGENT_SEED=ranking-fetch-agent-seed
NEGOTIATION_FETCH_AGENT_SEED=negotiation-fetch-agent-seed
