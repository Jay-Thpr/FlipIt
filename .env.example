# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000

# Agent networking
AGENT_HOST=127.0.0.1
AGENT_EXECUTION_MODE=local_functions

# Internal security
INTERNAL_API_TOKEN=dev-internal-token
INTERNAL_SECRET=diamondhacks-dev-secret

# Agent execution
AGENT_TIMEOUT_SECONDS=30
BUY_AGENT_MAX_RETRIES=1

# Browser Use / Gemini
GOOGLE_API_KEY=
ANONYMIZED_TELEMETRY=false
BROWSER_USE_GEMINI_MODEL=gemini-2.0-flash
BROWSER_USE_PROFILE_ROOT=profiles
BROWSER_USE_MAX_STEPS=15
BROWSER_USE_FORCE_FALLBACK=false

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-for-client-reads-if-needed
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-fastapi-only

# Backend usage note
# - Use SUPABASE_SERVICE_ROLE_KEY only in the server.
# - Do not ship the service role key in the mobile app.
